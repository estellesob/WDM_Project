        "https://pubmed.ncbi.nlm.nih.gov/41814902/"^^xsd:anyURI,
        "https://pubmed.ncbi.nlm.nih.gov/41815598/"^^xsd:anyURI,
        "https://pubmed.ncbi.nlm.nih.gov/41833345/"^^xsd:anyURI,
        "https://pubmed.ncbi.nlm.nih.gov/41835721/"^^xsd:anyURI,
        "https://pubmed.ncbi.nlm.nih.gov/41846741/"^^xsd:anyURI ;
    prop:start_on base:antibiotics .

