base:1_month_to_12_years a type:Date ;
    rdfs:label "1 month to 12 years" ;
    prop:assess_within base:the_first_five_days ;
    prop:extractedFrom "Another study involving 70 PICU-admitted children (aged 1 month to 12 years) assessed ferritin levels within the first five days of illness and found that a cutoff of 558 ng/mL predicted mortality with 74.1% sensitivity and 67.7% specificity." ;
