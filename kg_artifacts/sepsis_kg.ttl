base:Alexander_Ogston a type:Person ;
    rdfs:label "Alexander Ogston" ;
    prop:discover_editIn base:1880 ;
    prop:extractedFrom """Up to 50,000 deaths each year in the U.S. are linked to staphylococcal infection.[9]
History
[edit]Discovery
[edit]In 1880, Alexander Ogston, a Scottish surgeon, discovered that Staphylococcus can cause wound infections after noticing groups of bacteria in pus from a surgical abscess during a procedure he was performing.""" ;
    prop:sourceUrl "https://en.wikipedia.org/wiki/Staphylococcus_aureus"^^xsd:anyURI .

