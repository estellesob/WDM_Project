base:German_Trauma_Society a type:Org ;
    rdfs:label "German Trauma Society" ;
    prop:define_in base:2016 ;
    prop:extractedFrom "Displayed criteria were defined by German polytrauma standard care guidelines of German Trauma Society (DGU) in 2016 Motor vehicle accident with: - Ejection from the vehicle - Delta velocity of > 30 km/h - Vehicle body intrusion of more than 50–75 cm - Collision of pedestrian or (motor)cyclist with car/truck - Death of a passenger of the same vehicle *:" ;
    prop:sourceUrl "https://www.ncbi.nlm.nih.gov/pmc/articles/PMCPMC13013202/"^^xsd:anyURI .

base:Germany13 a type:Date ;
    rdfs:label "Germany13" ;
    prop:analyse base:enterococcus ;
    prop:extractedFrom "A large cohort study conducted in Germany13 in 2018 analysed the possible influence of vancomycin resistance and Enterococcus subspecies on in-hospital mortality in enterococci BSIs; in the univariate analysis an association between higher mortality and vancomycin resistance in E. faecium was found, together with higher mortality and VSE strains compared with vancomycin-susceptible E. faecalis strains; however, the vancomycin resistance role as mortality increasing factor was not confirmed in the multivariate analysis after adjusting for underlying disease, age and Enterococcus species." ;
    prop:sourceUrl "https://www.ncbi.nlm.nih.gov/pmc/articles/PMCPMC13016866/"^^xsd:anyURI .

