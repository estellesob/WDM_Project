base:Novartis_Vaccines_and_Diagnostics a type:Org ;
    rdfs:label "Novartis Vaccines and Diagnostics" ;
    prop:extractedFrom """In 2015, Novartis Vaccines and Diagnostics, a former division of Novartis and now part of GlaxoSmithKline, published promising pre-clinical results of their four-component Staphylococcus aureus vaccine, 4C-staph.[172]
In addition to vaccine development, research is being performed to develop alternative treatment options that are effective against antibiotic resistant strains including MRSA.""" ;
    prop:publish_In base:2015,
        base:staphylococcus_aureus ;
    prop:sourceUrl "https://en.wikipedia.org/wiki/Staphylococcus_aureus"^^xsd:anyURI .

