base:blood_culture a type:Treatment ;
    rdfs:label "blood culture" ;
    prop:enrol_from base:Southern_University_of_Science_and_Technology,
        base:between_February_2020_and_August_2023 ;
    prop:extractedFrom "Any patient presenting with signs or symptoms of bacteremia or a positive blood culture should be started on intravenous antibiotics.[23]",
        "Seventeen neonates with blood culture-positive sepsis and seventeen controls with negative blood culture results were enrolled from the Neonatal Intensive Care Unit of Guangdong Women and Children Hospital （Women and Children's Hospital， Southern University of Science and Technology） between February 2020 and August 2023." ;
    prop:sourceUrl "https://en.wikipedia.org/wiki/Bacteremia"^^xsd:anyURI,
        "https://en.wikipedia.org/wiki/Sepsis"^^xsd:anyURI,
        "https://en.wikipedia.org/wiki/Septic_shock"^^xsd:anyURI,
        "https://pubmed.ncbi.nlm.nih.gov/41630340/"^^xsd:anyURI,
        "https://pubmed.ncbi.nlm.nih.gov/41785728/"^^xsd:anyURI,
