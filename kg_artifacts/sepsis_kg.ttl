base:ferritin a type:Biomarker ;
    rdfs:label "ferritin" ;
    prop:become_In base:older_than_six_months ;
    prop:extractedFrom "In children older than six months, ferritin becomes a reliable biomarker, as earlier levels are influenced by maternal iron stores and the physiological transition from fetal to adult hemoglobin.",
        "Tonial et al[10] reported that a combination of ferritin, lactate, and CRP predicted mortality in approximately 43% of pediatric sepsis patients, and it increased to 76% when the Pediatric Index of Mortality 2 score was added." ;
