base:procalcitonin a type:Biomarker ;
    rdfs:label "procalcitonin" ;
    prop:combine_with base:sepsis ;
    prop:decrease_with base:Seraph ;
    prop:demonstrate_compared base:lactate ;
    prop:emerge_as base:antibiotic ;
    prop:extractedFrom "\"Elevated procalcitonin predicts Gram-negative sepsis in haematological patients with febrile neutropenia\".",
        "\"Procalcitonin (PCT)-guided algorithm reduces length of antibiotic treatment in surgical intensive care patients with severe sepsis: results of a prospective randomized study\".",
        "\"Procalcitonin reflects bacteremia and bacterial load in urosepsis syndrome: a prospective observational study\".",
        "Binary logistic regression analysis identified procalcitonin and HFREP1 as independent predictors of community-acquired pneumonia-sepsis, while C-reactive protein was not an independent predictor.",
        "Lactate and procalcitonin combined with qSOFA score for the evaluation of disease severity and prognosis in ICU patients with sepsis: a retrospective study",
        "Procalcitonin (PCT), a biomarker closely associated with bacterial infections, has emerged as a valuable tool in guiding antibiotic therapy.",
        "Procalcitonin can be used as an indicator for sepsis because it is a marker for inflammation produced by cytokines and bacterial endotoxins.[44]",
        "Procalcitonin demonstrated superior predictive performance (area under the receiver operator characteristic curve [AUC] = 0.76) compared to lactate (AUC =. 0.56; P = < .001) or the Multinational Association for Supportive Care in Cancer (MASCC) score (AUC = 0.65; P = .03).20",
        "Procalcitonin has a good diagnostic accuracy in detecting bacterial sepsis in children and can complement blood culture in resource-limited settings.",
        "Procalcitonin, C reactive protein and lactates significantly decreased, with a reduced ICU stay in the Seraph group.",
        "The authors suggested that procalcitonin may serve as a helpful diagnostic marker for sepsis, but cautioned that its level alone does not definitively make the diagnosis.[48]",
        "The use of procalcitonin guided antibiotic therapy leads to lower mortality, less antibiotic usage, decreased side effects due to antibiotics and promotes good antibiotic stewardship.[59]" ;
    prop:have base:sepsis ;
    prop:identify_as base:pneumonia ;
    prop:lead_to base:antibiotics ;
    prop:predict_in base:Scandinavian_Journal_of_Infectious_Diseases,
        base:sepsis ;
    prop:reduce base:antibiotic ;
    prop:reflect_in base:bacteremia ;
    prop:serve_as base:sepsis ;
