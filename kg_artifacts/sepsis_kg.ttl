base:28_day a type:Date ;
    rdfs:label "28-day" ;
    prop:extractedFrom "Dynamic 14-day Platelet Count Predicts 28-day Mortality in Sepsis: A Single-Center Retrospective Cohort Study..",
        "H pylori urea antibody and anti-herpes simplex virus type 1 immunoglobulin G seropositivity are pathogenic factors for sepsis, while cytomegalovirus phosphoprotein 52 antibody levels may protect against 28-day mortality in sepsis.",
        "No significant difference was found in 28-day mortality.",
        "The primary end point was 90-day mortality; secondary end points included 28-day, 60-day, intensive care unit and in-hospital mortality, organ dysfunction or failure, total amount of fluid administration and total fluid balance while in the intensive care unit, duration of intensive care and hospital stays, and frequency of adverse events." ;
    prop:find_in base:pct ;
    prop:include base:intensive_care_unit ;
    prop:predict base:sepsis ;
    prop:protect_against base:sepsis ;
