base:piperacillin a type:Treatment ;
    rdfs:label "piperacillin" ;
    prop:associate_In base:antibiotic ;
    prop:extractedFrom """Extended generation cephalosporins such as ceftriaxone or beta lactam/beta lactamase inhibitor antibiotics such as piperacillin-tazobactam are frequently used for the treatment of gram negative bacteremia.[49]
Catheter-associated infections
[edit]For healthcare-associated bacteremia due to intravenous catheters, the IDSA has published guidelines for catheter removal.""",
        """In children, concomitant administration of vancomycin and piperacillin/tazobactam has been associated with an elevated incidence of AKI relative to other antibiotic regimens.[48]
Ototoxicity
[edit]Attempts to establish rates of vancomycin-induced ototoxicity are even more difficult due to lack of good data.""" ;
    prop:sourceUrl "https://en.wikipedia.org/wiki/Bacteremia"^^xsd:anyURI,
        "https://en.wikipedia.org/wiki/Vancomycin"^^xsd:anyURI,
        "https://pubmed.ncbi.nlm.nih.gov/40571865/"^^xsd:anyURI,
        "https://www.ncbi.nlm.nih.gov/pmc/articles/PMCPMC13010318/"^^xsd:anyURI,
        "https://www.ncbi.nlm.nih.gov/pmc/articles/PMCPMC13010603/"^^xsd:anyURI,
        "https://www.ncbi.nlm.nih.gov/pmc/articles/PMCPMC13012176/"^^xsd:anyURI,
        "https://www.ncbi.nlm.nih.gov/pmc/articles/PMCPMC13013790/"^^xsd:anyURI,
        "https://www.ncbi.nlm.nih.gov/pmc/articles/PMCPMC13014954/"^^xsd:anyURI,
        "https://www.ncbi.nlm.nih.gov/pmc/articles/PMCPMC13014981/"^^xsd:anyURI,
        "https://www.ncbi.nlm.nih.gov/pmc/articles/PMCPMC13015098/"^^xsd:anyURI,
        "https://www.ncbi.nlm.nih.gov/pmc/articles/PMCPMC13016320/"^^xsd:anyURI,
        "https://www.ncbi.nlm.nih.gov/pmc/articles/PMCPMC13016333/"^^xsd:anyURI ;
    prop:use_for base:bacteremia .

