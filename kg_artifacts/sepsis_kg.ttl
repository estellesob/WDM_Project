base:VentCoach a type:Org,
        type:Product ;
    rdfs:label "VentCoach" ;
    prop:extractedFrom "While this feasibility study was not powered to detect statistically significant differences in secondary clinical outcomes, the primary mechanistic question was whether VentCoach could reduce MP over 24 h. Although the between-group difference in MP change did not reach statistical significance, the direction of effect favored VentCoach (median change − 2.0 vs. + 0.6 J/min; p = 0.40), supporting the physiologic premise that reducing ergotrauma may be feasible20and could mitigate VILI risk7–10." ;
    prop:reduce_over base:24_h ;
    prop:sourceUrl "https://www.ncbi.nlm.nih.gov/pmc/articles/PMCPMC13013959/"^^xsd:anyURI .

