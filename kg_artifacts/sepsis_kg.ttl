base:Berkhout a type:Person ;
    rdfs:label "Berkhout" ;
    prop:extractedFrom "The relationship between IEAT and NEC remains controversial: Li et al. and Berkhout et al. reported a protective effect of IEAT in relation to NEC with adjusted odds ratios of 0.25 (95% CI: 0.12–0.47) and 0.23 (95% CI: 0.08–0.65), respectively [1, 24]; Vatne et al. and Zhu et al. reported neither a protective nor a harmful effect of IEAT in relation to NEC [23, 25]; whereas Greenwood et al. reported that infants who received IEAT experienced more cases of NEC [26]." ;
    prop:report_with base:Vatne ;
    prop:sourceUrl "https://www.ncbi.nlm.nih.gov/pmc/articles/PMCPMC13015168/"^^xsd:anyURI .

