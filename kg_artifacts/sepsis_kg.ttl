base:dic a type:Disease ;
    rdfs:label "dic" ;
    prop:associate_with base:sepsis ;
    prop:describe base:d_dimer ;
    prop:describe_as base:organ_dysfunction ;
    prop:extractedFrom "DIC is most frequently associated with severe infection and sepsis, followed by trauma, malignancy, immune and inflammatory diseases and obstetric complications, particularly in critically ill patients [3].",
        "Disseminated Intravascular Coagulopathy (DIC) represents a critical complication of sepsis, contributing to increased mortality and economic burden.",
        "Disseminated intravascular coagulation (DIC) has long been described as a catastrophic systemic activation of coagulation with suppressed anticoagulant and fibrinolytic pathways, culminating in macro- and microvascular thrombosis, hypoperfusion, and multiple organ dysfunction.",
        "Patients with DIC had notably lower platelet (PLT) and higher levels of prothrombin time (PT), lactate (LAC), and procalcitonin (PCT) compared to those without DIC.",
        "Reported cases of malaria-associated DIC, including those involving Plasmodium vivax and Plasmodium falciparum, typically describe profound thrombocytopenia, elevated D-dimer levels, and multiorgan dysfunction, but more often emphasise hemorrhagic manifestations rather than arterial thrombosis [7-9]." ;
    prop:have_compared base:procalcitonin ;
    prop:represent base:sepsis ;
    prop:sourceUrl "https://en.wikipedia.org/wiki/Septic_shock"^^xsd:anyURI,
        "https://pubmed.ncbi.nlm.nih.gov/39465188/"^^xsd:anyURI,
        "https://pubmed.ncbi.nlm.nih.gov/41667115/"^^xsd:anyURI,
        "https://pubmed.ncbi.nlm.nih.gov/41743702/"^^xsd:anyURI,
        "https://pubmed.ncbi.nlm.nih.gov/41773857/"^^xsd:anyURI,
        "https://pubmed.ncbi.nlm.nih.gov/41788491/"^^xsd:anyURI,
        "https://pubmed.ncbi.nlm.nih.gov/41791773/"^^xsd:anyURI,
        "https://pubmed.ncbi.nlm.nih.gov/41840740/"^^xsd:anyURI,
        "https://pubmed.ncbi.nlm.nih.gov/41843129/"^^xsd:anyURI,
        "https://pubmed.ncbi.nlm.nih.gov/41859212/"^^xsd:anyURI,
        "https://pubmed.ncbi.nlm.nih.gov/41869834/"^^xsd:anyURI,
        "https://www.ncbi.nlm.nih.gov/pmc/articles/PMCPMC13010318/"^^xsd:anyURI,
        "https://www.ncbi.nlm.nih.gov/pmc/articles/PMCPMC13015761/"^^xsd:anyURI .

