base:2018 a type:Date ;
    rdfs:label "2018" ;
    prop:evaluate base:30_day,
        base:ed ;
    prop:extractedFrom "Javaudin et al (2018) evaluated the capacity of SpO2, ETCO2, and systolic BP to predict 30-day neurologic outcomes in patients who arrested and achieved return of spontaneous circulation (ROSC) in the prehospital setting; significant relative risks of worse outcomes were observed for SpO2 < 94% (RR 1.108, 95% CI, 1.069–1.147), ETCO2 < 30 or > 40 (< 20 RR 1.191 (95% CI, 1.143–1.229); 20–29, RR 1.092 (95% CI, 1.061–1.123); 41–50, RR 1.075 (95% CI, 1.039–1.110); > 50, RR 1.136 (1.085–1.179), and SBP < 100 or > 130 mm Hg.18",
        "Reed et al (2018) evaluated the utility of continuous smartphone-based event recording for the timely diagnosis of symptomatic arrythmias not initially captured upon initial presentation to the ED in patients with palpitations and presyncope." ;
    prop:sourceUrl "https://en.wikipedia.org/wiki/Escherichia_coli"^^xsd:anyURI,
