base:staphylococcus_aureus a type:Bacteria ;
    rdfs:label "staphylococcus aureus" ;
    prop:contribute_to base:Frontiers_in_Microbiology ;
    prop:culture_on base:Oxoid_Ltd ;
    prop:extractedFrom "\"A Novel ESAT-6 Secretion System-Secreted Protein EsxX of Community-Associated Staphylococcus aureus Lineage ST398 Contributes to Immune Evasion and Virulence\".",
        "\"The type VII secretion system of Staphylococcus aureus secretes a nuclease toxin that targets competitor bacteria\".",
        "E. coli (LMG:2092), M. flavus (DSM 19079) were cultured on Luria–Bertani Broth (LB) and agar (Oxoid Ltd); Pseudomonas aeruginosa (ATCC® 9027™) and Proteus mirabilis were cultured on Brain Heart Infusion (BHI) broth and agar (Oxoid Ltd); Staphylococcus aureus (ATCC® 6538™), Salmonella enterica subsp. enterica serovar Typhimurium (ATCC® 14028GFP™), Enteroinvasive Escherichia coli (EIEC) (ATCC® 43,893™), Enterococcus faecalis (ATCC® 9027™), Streptococcus pyogenes, carbapenem-resistant Klebsiella pneumoniae, and methicillin-resistant Staphylococcus aureus were cultured on Tryptic Soy Broth (TSB) and Tryptic Soy Agar (TSA) (Oxoid Ltd);" ;
    prop:secrete base:Nature_Microbiology ;
