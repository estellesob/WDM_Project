    prop:include_in base:sepsis ;
    prop:increase_at base:age_60 ;
    prop:investigate_in base:5_days,
        base:sepsis ;
    prop:present_with base:lactate ;
    prop:screen_Between base:Between_February_2022_and_July_2023 ;
