base:pct a type:Biomarker ;
    rdfs:label "pct" ;
    prop:emerge_as base:sepsis ;
    prop:extractedFrom "In the study, PCT outperformed CRP in diagnostic accuracy of predicting sepsis.[56]",
        """PCT also outperformed other biomarkers such as C-reactive protein.[69]
Gastrointestinal disease
[edit]Evidence shows that an elevated PCT above .5 ng/mL could help diagnose infectious complications of inflammatory bowel disease such as abdominal abscesses, bacterial enterocolitis etc.""",
        "PCT is emerging as a universal biomarker for both bacterial and non-bacterial sepsis, making it a potential universal marker for sepsis.",
        "PCT reduces antibiotic exposure during outbreak of viral meningitis |",
        "This followed a 2015 meta analysis that showed that PCT had a sensitivity of 90% and a specificity of 98% in judging viral versus bacterial meningitis.",
        """[47][50] |
Medical uses
[edit]Sepsis
[edit]Measurement of procalcitonin can be used as a marker of severe sepsis caused by bacteria and generally grades well with the degree of sepsis,[51] although levels of procalcitonin in the blood are very low. PCT has the greatest sensitivity (90%) and specificity (91%) for differentiating patients with systemic inflammatory response syndrome (SIRS) from those with sepsis, when compared with IL-2, IL-6, IL-8, CRP and TNF-alpha.[52]""",
        """]
Pediatrics
[edit]In a meta analysis of 17 studies, PCT had a sensitivity of 85% and a specificity of 54% in diagnosing sepsis in neonates and children.""",
        """|
| Postoperative infections | RCT | 0.5-1.0; 75-85% ↓ | ✓✓ | PCT reduces antibiotic exposure without adverse outcomes in the surgical ICU |""",
        "| Pneumonia | RCT | 0.1-0. 5; 80-90% ↓ | ✓✓✓ | PCT reduces antibiotic without adverse outcomes exposure in the hospital |",
        "✓✓✓ | PCT reduces antibiotic exposure without adverse outcomes in the ED |" ;
    prop:have base:meningitis,
        base:sepsis ;
    prop:have_editIn base:sepsis ;
    prop:outperform base:c_reactive_protein ;
    prop:outperform_In base:crp,
        base:sepsis ;
    prop:reduce_during base:meningitis ;
    prop:reduce_without base:antibiotic,
        base:ed,
        base:icu ;
    prop:sourceUrl "https://en.wikipedia.org/wiki/Procalcitonin"^^xsd:anyURI,
        "https://en.wikipedia.org/wiki/Sepsis"^^xsd:anyURI,
        "https://pubmed.ncbi.nlm.nih.gov/41790922/"^^xsd:anyURI,
        "https://pubmed.ncbi.nlm.nih.gov/41824856/"^^xsd:anyURI,
        "https://pubmed.ncbi.nlm.nih.gov/41846741/"^^xsd:anyURI,
        "https://pubmed.ncbi.nlm.nih.gov/41872955/"^^xsd:anyURI,
        "https://pubmed.ncbi.nlm.nih.gov/41873329/"^^xsd:anyURI,
        "https://pubmed.ncbi.nlm.nih.gov/41876236/"^^xsd:anyURI .

base:qsofa a type:Biomarker ;
    rdfs:label "qsofa" ;
    prop:extractedFrom "\"qSOFA does not replace SIRS in the definition of sepsis\".",
        "NOTE - Surviving Sepsis Campaign 2021 Guidelines recommend \"against using qSOFA compared with SIRS, NEWS, or MEWS as a single screening tool for sepsis or septic shock\".[54]",
        "The SOFA score was intended to be used in the intensive care unit (ICU) where it is administered upon admission to the ICU and then repeated every 48 hours, whereas the qSOFA could be used outside the ICU.[21]",
        "The three criteria for the qSOFA score include a respiratory rate greater than or equal to 22 breaths per minute, systolic blood pressure 100 mmHg or less, and altered mental status.[4]" ;
    prop:include base:sepsis ;
    prop:recommend_against base:septic_shock ;
    prop:replace_in base:SIRS,
        base:sepsis ;
    prop:sourceUrl "https://en.wikipedia.org/wiki/Sepsis"^^xsd:anyURI,
