base:ed a type:CareUnit ;
    rdfs:label "ed" ;
    prop:associate_with base:sepsis ;
    prop:demonstrate base:antibiotic ;
    prop:extractedFrom "Chukwulebe et al (2021) showed that the admission rate from the ED was better predicted by serum lactate (AUROC = 0.83, 95% CI, 0.64–0.92) than cardiac output (AUROC = 0.59, 95% CI, 0.41–0.73) and cardiac index (AUROC = 0.63, 95% CI, 0.36–0.80) in 50 ED patients at risk for sepsis.47",
        "The high-resource ED demonstrated lower mortality, a shorter length of the ICU stay, and shorter times to antibiotic and IV fluid administration vs the limited-resource ED.",
        "This study evaluated whether total ED length of stay (ED-LOS) and delays in specialist visit and disposition decisions were associated with 30-day mortality among adult patients with sepsis." ;
    prop:predict_in base:sepsis ;
