base:sepsis a type:Disease ;
    rdfs:label "sepsis" ;
    prop:associate_with base:acute_kidney_injury ;
    prop:compare_with base:procalcitonin ;
    prop:exhibit_Compared base:il_6 ;
    prop:extractedFrom "Aminoglycoside dosing in suspected neonatal sepsis remains difficult due to highly variable pharmacokinetics driven by marked physiological diversity, from extremely preterm to term neonates, and further complicated by acute kidney injury, perinatal asphyxia, and concomitant interventions.",
        "Compared with controls, patients with sepsis exhibited significantly higher serum levels of TLR2, TLR4, TLR9, IL-1β, IL-6, IL-8, IL-10 and TNF-α (all p < 0.05), whereas IFN-γ levels were not significantly different.",
        "Evaluation of serum amyloid A as a biomarker for sepsis diagnosis compared with C-reactive protein, procalcitonin, and presepsin..",
        "Independent predictors of postoperative sepsis included failure of microbiological eradication, higher baseline C-reactive protein, and larger stone burden.",
        "Male and female subjects with sepsis had comparable CRP, serum albumin, lymphocyte count, CALLY indices, and SOFA scores.",
        "No significant differences in baseline characteristics were found between the two groups (all  The use of vitamin C in patients with sepsis is associated with a reduced incidence of acute kidney injury, although a larger sample size is required to confirm this finding.",
        "Patients with suspected neutropenic sepsis require treatment with intravenous antibiotics within one hour of presentation to hospital.",
        "Sepsis remains a leading cause of morbidity and mortality among patients presenting to the emergency department (ED), and early risk stratification is crucial for clinical decision-making.",
        "To explore whether vitamin C supplementation in sepsis patients can reduce the occurrence of acute kidney injury." ;
    prop:have base:crp ;
    prop:include base:c_reactive_protein ;
    prop:reduce base:acute_kidney_injury ;
    prop:remain base:emergency_department ;
    prop:remain_due base:acute_kidney_injury ;
    prop:require_within base:antibiotics ;
    prop:sourceUrl "https://pubmed.ncbi.nlm.nih.gov/41457243/"^^xsd:anyURI,
        "https://pubmed.ncbi.nlm.nih.gov/41505938/"^^xsd:anyURI,
        "https://pubmed.ncbi.nlm.nih.gov/41512697/"^^xsd:anyURI,
