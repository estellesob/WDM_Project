base:heparin a type:Treatment ;
    rdfs:label "heparin" ;
    prop:extractedFrom "Given the thrombotic-predominant presentation of DIC and absence of active bleeding, anticoagulation with unfractionated heparin was initiated under close hematologic monitoring (continuous infusion at 10 U/kg/hour, without an initial bolus).",
        "Low-molecular-weight heparin (LMWH), unfractionated heparin (UFH), and mechanical prophylaxis with intermittent pneumatic compression devices are recommended for any person with sepsis at moderate to high risk of venous thromboembolism.[5]" ;
    prop:initiate_Given base:dic ;
    prop:recommend_for base:sepsis ;
    prop:sourceUrl "https://en.wikipedia.org/wiki/Sepsis"^^xsd:anyURI,
