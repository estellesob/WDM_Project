base:endocarditis a type:Disease ;
    rdfs:label "endocarditis" ;
    prop:consider_in base:sepsis ;
    prop:extractedFrom "Endocarditis should be considered in any patient with fever or sepsis of unknown origin.",
        """However, specific infections such as endocarditis and osteomyelitis and infections caused by indwelling devices that cannot be removed may require longer durations of antibiotic therapy.[1]
Specific antibiotic treatment choices for different infections causing sepsis
[edit]Meningitis
[edit]To treat meningitis-related sepsis, one can administer vancomycin, ceftriaxone, ampicillin, and dexamethasone (a corticosteroid used as an anti-inflammatory to reduce neuro complications).[52]""" ;
    prop:require base:antibiotic,
        base:meningitis ;
    prop:sourceUrl "https://en.wikipedia.org/wiki/Bacteremia"^^xsd:anyURI,
        "https://en.wikipedia.org/wiki/Procalcitonin"^^xsd:anyURI,
        "https://en.wikipedia.org/wiki/Septic_shock"^^xsd:anyURI,
        "https://en.wikipedia.org/wiki/Staphylococcus_aureus"^^xsd:anyURI,
        "https://en.wikipedia.org/wiki/Streptococcus_pneumoniae"^^xsd:anyURI,
        "https://en.wikipedia.org/wiki/Vancomycin"^^xsd:anyURI,
        "https://pubmed.ncbi.nlm.nih.gov/41505938/"^^xsd:anyURI,
        "https://pubmed.ncbi.nlm.nih.gov/41839106/"^^xsd:anyURI,
        "https://pubmed.ncbi.nlm.nih.gov/41850617/"^^xsd:anyURI,
        "https://pubmed.ncbi.nlm.nih.gov/41869215/"^^xsd:anyURI .

base:escherichia_coli a type:Bacteria ;
    rdfs:label "escherichia coli" ;
