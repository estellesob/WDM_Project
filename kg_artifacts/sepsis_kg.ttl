base:antibiotics a type:Treatment ;
    rdfs:label "antibiotics" ;
    prop:administer_after base:sepsis ;
    prop:continue_under base:Ertapenem_Metronidazole ;
    prop:contribute_to base:staphylococcus_aureus ;
    prop:document_with base:staphylococcus_aureus ;
    prop:extractedFrom "A systematic review of antibiotics and pediatric gut microbiome disruption revealed consistent evidence of reduced richness, diversity, and taxonomic alterations following antibiotic use in children [466].",
        "At one point it was recommended that antibiotics be administered one hour after initial recognition of sepsis.[1]",
        "Empiric antibiotics should be narrowed, preferably to a single antibiotic, once the blood culture returns with a particular bacteria that has been isolated.[47",
        "However, the widespread use of empirical antibiotics has contributed to the emergence of antimicrobial resistance (AMR), including multidrug-resistant organisms such as methicillin-resistant Staphylococcus aureus (MRSA) and extended-spectrum beta-lactamase (ESBL)–producing Gram-negative bacteria.",
        "In severe sepsis and septic shock, broad-spectrum antibiotics (usually two, a β-lactam antibiotic with broad coverage, or broad-spectrum carbapenem combined with fluoroquinolones, macrolides, or aminoglycosides) are recommended.",
        "Intraventricular antibiotics used included colistin, vancomycin, tigecycline, and amikacin.",
        "New or changes in antibiotics were initiated in 38.8 % of sepsis-related RRTs.",
        "Other antibiotics, including methicillin (introduced in 1959), faced resistance within a year of their introduction [8].",
        "Resistance to the first antibiotics, notably penicillin, was documented as early as the 1940 s, with the emergence of resistant strains of Staphylococcus aureus [7].",
        "Subcapsular transplant nephrectomy; drain placement Antibiotics and prednisone continued Progressive clinical improvement under continued Ertapenem + Metronidazole.",
        "The antibiotics tested included ampicillin, gentamicin, ceftriaxone, cefepime, amikacin, meropenem, imipenem, vancomycin, trimethoprim-sulfamethoxazole, clindamycin, and others according to hospital protocol.",
        "The timely initiation of appropriate antibiotics improves the outcomes in children admitted with sepsis; however, prolonged antibiotic use increases the risk of developing antimicrobial resistance.",
        "Third-line antibiotics: Includes amikacin, piperacillin–tazobactam, cefepime, vancomycin, and ciprofloxacin [1,31]." ;
    prop:face_within base:a_year ;
    prop:improve base:sepsis ;
    prop:include base:piperacillin,
        base:vancomycin ;
    prop:include_according base:vancomycin ;
    prop:initiate_in base:sepsis ;
    prop:narrow_to base:antibiotic ;
    prop:recommend_In base:septic_shock ;
    prop:reveal base:antibiotic ;
