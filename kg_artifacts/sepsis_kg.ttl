base:intensive_care_unit a type:CareUnit ;
    rdfs:label "intensive care unit" ;
    prop:conduct_at base:Asella_Referral_and_Teaching_Hospital ;
    prop:enrol_In base:sepsis ;
    prop:enrol_as base:sepsis,
        base:the_1st_day ;
    prop:extractedFrom "An institution-based retrospective cross-sectional study was conducted at the neonatal intensive care unit (NICU) of Asella Referral and Teaching Hospital (ARTH) in Asella town, Southeast Ethiopia, located approximately 175 km south of Addis Ababa.",
        "Despite an increasing cancer burden in Saudi Arabia, data on intensive care unit (ICU) outcomes, particularly in the Najran region, remain limited.",
        "In this hospital-based case-control study, 480 adult patients with sepsis admitted to the intensive care unit and 840 age- and sex-matched healthy controls were enrolled.",
        "The patients with sepsis admitted to intensive care unit (ICU) of Zhejiang Hospital from November 2020 to December 2021 were enrolled as the study subjects.",
        "The risk factors for a lethal outcome during the first week of intensive care unit stay included signs of hemophagocytosis, progressive decline in the Glasgow Coma Scale, increasing Sequential Organ Failure Assessment scores, and persistent high C-reactive protein levels.",
        "Twenty non-sepsis patients without AGI admitted to the intensive care unit during the same period were enrolled as the control group (non-sepsis group)." ;
    prop:include base:c_reactive_protein ;
    prop:remain_Despite base:Saudi_Arabia ;
