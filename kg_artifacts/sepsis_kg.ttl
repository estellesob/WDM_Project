base:2025 a type:Date ;
    rdfs:label "2025" ;
    prop:apply_For base:Jamaica_Bay ;
    prop:develop base:the_Pearl_River_Delta ;
    prop:extractedFrom "For example, Rosenzweig et al. (2025) applied the Coupled Ocean–Atmosphere-Wave-Sediment Transport (COAWST) system to Jamaica Bay, New York, to simulate pluvial and coastal flooding during Post-Tropical Cyclone Ida, capturing interactions among extreme rainfall, storm surge, and tidal forcing24.",
        "Liu et al. (2025) developed a fully coupled land-river-ocean coupled modeling system for the Pearl River Delta, China, to simulate compound flooding driven by storm surge, tides, river discharge, and precipitation during multiple typhoon events25." ;
    prop:sourceUrl "https://en.wikipedia.org/wiki/Bacteremia"^^xsd:anyURI,
